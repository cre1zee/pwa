        <title>
            Pillowy Reminders • Glass Pastel • Pro Timer & Custom Noti
        </title>

        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                -webkit-tap-highlight-color: transparent;
            }

            body {
                min-height: 100vh;
                background: linear-gradient(145deg, #ffe4ec 0%, #fbc4d2 100%);
                font-family:
                    system-ui,
                    -apple-system,
                    "Segoe UI",
                    "SF Pro Text",
                    "Inter",
                    Helvetica,
                    sans-serif;
                padding: 20px 16px 32px;
                color: #3a2c28;
                position: relative;
            }

            /* floating glass orbs */
            body::before {
                content: "";
                position: fixed;
                top: -15%;
                left: -5%;
                width: 280px;
                height: 280px;
                background: radial-gradient(
                    circle,
                    rgba(255, 215, 230, 0.6) 0%,
                    rgba(255, 200, 210, 0) 70%
                );
                border-radius: 50%;
                pointer-events: none;
                z-index: 0;
                animation: floatOrb 16s infinite alternate;
            }
            body::after {
                content: "";
                position: fixed;
                bottom: -10%;
                right: -5%;
                width: 380px;
                height: 380px;
                background: radial-gradient(
                    circle,
                    rgba(255, 200, 215, 0.5) 0%,
                    rgba(255, 180, 200, 0) 70%
                );
                border-radius: 50%;
                pointer-events: none;
                z-index: 0;
                animation: floatOrb2 20s infinite alternate;
            }

            @keyframes floatOrb {
                0% {
                    transform: translate(0, 0) scale(1);
                    opacity: 0.5;
                }
                100% {
                    transform: translate(40px, 35px) scale(1.2);
                    opacity: 0.8;
                }
            }
            @keyframes floatOrb2 {
                0% {
                    transform: translate(0, 0) scale(1);
                    opacity: 0.4;
                }
                100% {
                    transform: translate(-30px, -40px) scale(1.3);
                    opacity: 0.7;
                }
            }

            .app-container {
                max-width: 500px;
                margin: 0 auto;
                background: rgba(255, 245, 245, 0.35);
                backdrop-filter: blur(18px) saturate(180%);
                -webkit-backdrop-filter: blur(18px);
                border-radius: 56px;
                box-shadow:
                    0 20px 40px rgba(0, 0, 0, 0.08),
                    inset 0 1px 0 rgba(255, 255, 255, 0.6);
                overflow: hidden;
                padding-bottom: 12px;
                border: 1px solid rgba(255, 255, 255, 0.5);
                position: relative;
                z-index: 2;
            }

            .status-bar {
                padding: 14px 20px 6px;
                font-size: 15px;
                font-weight: 590;
                color: #5a3e36;
                display: flex;
                justify-content: space-between;
                background: rgba(255, 240, 240, 0.3);
                backdrop-filter: blur(4px);
                border-bottom: 1px solid rgba(255, 215, 215, 0.5);
            }

            .tab-bar {
                display: flex;
                justify-content: space-around;
                align-items: center;
                background: rgba(255, 245, 245, 0.5);
                backdrop-filter: blur(20px);
                border-top: 1px solid rgba(255, 255, 255, 0.6);
                padding: 8px 20px 14px;
                margin-top: 8px;
            }

            .tab-item {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 5px;
                font-size: 12px;
                font-weight: 500;
                color: #ad7a68;
                background: transparent;
                border: none;
                font-family: inherit;
                cursor: pointer;
                padding: 6px 12px;
                border-radius: 40px;
                transition: all 0.2s ease;
            }

            .tab-item.active {
                color: #e36b5e;
                background: rgba(255, 220, 210, 0.6);
                font-weight: 600;
            }

            .tab-icon {
                font-size: 22px;
            }

            .page {
                display: none;
                padding: 20px 20px 10px;
                animation: fadeSlideGlass 0.3s ease;
            }

            .page.active-page {
                display: block;
            }

            @keyframes fadeSlideGlass {
                from {
                    opacity: 0;
                    transform: translateY(10px) scale(0.98);
                }
                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }

            /* glass cards */
            .streak-card,
            .focus-card,
            .reminder-card,
            .glass-panel {
                background: rgba(255, 250, 245, 0.55);
                backdrop-filter: blur(12px);
                border-radius: 40px;
                padding: 20px 18px;
                margin-bottom: 20px;
                box-shadow:
                    0 8px 20px rgba(0, 0, 0, 0.05),
                    inset 0 1px 0 rgba(255, 255, 255, 0.7);
                border: 1px solid rgba(255, 255, 255, 0.5);
            }

            .streak-number {
                font-size: 56px;
                font-weight: 800;
                background: linear-gradient(135deg, #e6826b, #d45a46);
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                line-height: 1;
            }

            .section-title {
                font-weight: 640;
                font-size: 18px;
                display: flex;
                justify-content: space-between;
                margin: 20px 0 12px 0;
                color: #553b30;
            }

            .reminder-card {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 12px;
            }

            .reminder-time {
                font-weight: 700;
                background: rgba(227, 107, 94, 0.2);
                padding: 5px 12px;
                border-radius: 30px;
                color: #cb5e4a;
            }

            .calendar-grid {
                display: grid;
                grid-template-columns: repeat(7, 1fr);
                gap: 8px;
                margin: 16px 0;
            }

            .cal-day {
                text-align: center;
                font-size: 14px;
                font-weight: 500;
                padding: 8px 0;
                border-radius: 40px;
                background: rgba(255, 240, 235, 0.6);
                backdrop-filter: blur(4px);
            }

            .cal-day.today {
                background: #e36b5e;
                color: white;
                box-shadow: 0 4px 12px rgba(227, 107, 94, 0.3);
            }

            .cal-day.checked {
                background: rgba(210, 140, 110, 0.8);
                color: white;
            }

            /* timer preset buttons */
            .preset-group {
                display: flex;
                gap: 12px;
                justify-content: center;
                margin: 16px 0;
                flex-wrap: wrap;
            }
            .preset-btn {
                background: rgba(245, 220, 210, 0.8);
                backdrop-filter: blur(4px);
                padding: 8px 20px;
                border-radius: 40px;
                font-weight: 600;
                color: #9b5a48;
                border: none;
                font-size: 14px;
                cursor: pointer;
                transition: all 0.2s ease;
            }
            .preset-btn.active-preset {
                background: #e36b5e;
                color: white;
            }
            .preset-btn:active {
                transform: scale(0.96);
            }

            .timer-display {
                font-size: 52px;
                font-weight: 800;
                font-family: monospace;
                background: rgba(255, 250, 245, 0.7);
                backdrop-filter: blur(12px);
                display: inline-block;
                padding: 12px 28px;
                border-radius: 70px;
                margin: 12px 0;
            }

            .marshie-message {
                text-align: center;
                color: #9b6b5e;
                margin: 8px 0;
                font-style: italic;
                font-weight: 500;
            }

            input,
            textarea {
                background: rgba(255, 245, 240, 0.8);
                backdrop-filter: blur(8px);
                border: 1px solid rgba(255, 215, 200, 0.8);
                border-radius: 44px;
                padding: 12px 16px;
                font-size: 16px;
                width: 100%;
                font-family: inherit;
                outline: none;
            }

            textarea {
                border-radius: 24px;
                resize: vertical;
            }

            button {
                background: rgba(227, 107, 94, 0.85);
                backdrop-filter: blur(8px);
                border: none;
                padding: 12px 20px;
                border-radius: 44px;
                font-weight: 600;
                color: white;
                font-size: 16px;
                cursor: pointer;
                transition: 0.2s;
            }
            button:active {
                transform: scale(0.96);
            }
            button:disabled {
                opacity: 0.5;
                pointer-events: none;
            }

            .btn-outline {
                background: rgba(255, 245, 240, 0.7) !important;
                color: #e36b5e !important;
            }

            .notification-perm {
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 8px;
                font-size: 13px;
            }

            .toast-msg {
                position: fixed;
                bottom: 90px;
                left: 50%;
                transform: translateX(-50%);
                background: rgba(50, 35, 30, 0.85);
                backdrop-filter: blur(20px);
                color: #ffe3db;
                padding: 10px 20px;
                border-radius: 60px;
                font-size: 13px;
                z-index: 200;
                pointer-events: none;
                transition: opacity 0.2s;
                max-width: 90%;
                text-align: center;
            }

            .view-all-link {
                cursor: pointer;
                opacity: 0.7;
                transition: opacity 0.2s;
            }
            .view-all-link:hover {
                opacity: 1;
            }

            .badge-progress-container {
                background: rgba(255, 240, 235, 0.5);
                border-radius: 28px;
                padding: 16px;
                margin-top: 12px;
                text-align: center;
            }

            /* Browser Warning Styles */
            .browser-warning-card {
                background: rgba(255, 200, 150, 0.9);
                backdrop-filter: blur(8px);
                border-radius: 32px;
                padding: 20px;
                margin: 16px 0;
                border: 2px solid #ff8a5c;
                color: #4a2e26;
                text-align: center;
            }

            .browser-warning-card h3 {
                color: #c0392b;
                margin-bottom: 12px;
                font-size: 20px;
            }

            .browser-icon {
                font-size: 40px;
                margin: 8px 0;
            }

            .open-in-safari-btn {
                background: #007aff !important;
                color: white !important;
                width: 100%;
                padding: 16px;
                font-size: 18px;
                margin-top: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            }

            .open-in-safari-btn:disabled {
                opacity: 1 !important;
                pointer-events: all !important;
            }

            .safari-icon {
                font-size: 24px;
            }

            .dismiss-warning {
                background: transparent !important;
                color: #666 !important;
                margin-top: 8px;
                font-size: 14px;
            }

            /* iOS Guide Styles */
            .ios-guide-card {
                background: rgba(255, 235, 225, 0.9);
                backdrop-filter: blur(8px);
                border-radius: 32px;
                padding: 16px 20px;
                margin: 16px 0;
                border: 1px solid rgba(227, 107, 94, 0.3);
                font-size: 14px;
                color: #4a2e26;
            }

            .ios-guide-card strong {
                color: #e36b5e;
            }

            .modal-overlay {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.2);
                backdrop-filter: blur(4px);
                z-index: 1000;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.2s;
                padding: 20px;
            }

            .modal-overlay.show {
                opacity: 1;
                pointer-events: all;
            }

            .modal-card {
                max-width: 380px;
                background: rgba(255, 250, 245, 0.95);
                backdrop-filter: blur(20px);
                border-radius: 48px;
                padding: 24px;
                text-align: center;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
                border: 1px solid rgba(255, 255, 255, 0.8);
            }

            .modal-card p {
                margin: 16px 0;
                font-size: 16px;
            }

            .modal-actions {
                display: flex;
                gap: 12px;
                justify-content: center;
            }

            .modal-actions button {
                flex: 1;
                padding: 12px;
            }

            /* iOS Install Guide Modal (Visual) */
            .install-steps {
                display: flex;
                flex-direction: column;
                gap: 16px;
                margin: 20px 0;
            }

            .step-item {
                display: flex;
                align-items: center;
                gap: 12px;
                text-align: left;
                background: rgba(255, 240, 235, 0.5);
                padding: 12px 16px;
                border-radius: 24px;
            }

            .step-icon {
                background: #e36b5e;
                color: white;
                width: 32px;
                height: 32px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
                font-size: 16px;
                flex-shrink: 0;
            }

            .step-text {
                flex: 1;
                font-size: 14px;
                font-weight: 500;
            }

            .guide-button-group {
                display: flex;
                gap: 8px;
                margin-top: 16px;
            }
        </style>
    </head>
    <body>
        <!-- Custom Modal for Confirm Dialogs -->
        <div class="modal-overlay" id="confirmModal">
            <div class="modal-card">
                <div style="font-size: 40px">🧸</div>
                <p id="confirmModalMessage">Are you sure?</p>
                <div class="modal-actions">
                    <button class="btn-outline" id="confirmModalCancel">
                        Cancel
                    </button>
                    <button id="confirmModalOk">OK</button>
                </div>
            </div>
        </div>

        <!-- iOS Install Guide Modal (Visual Step-by-step) -->
        <div class="modal-overlay" id="installGuideModal">
            <div class="modal-card">
                <div style="font-size: 48px">📲</div>
                <h3 style="margin: 8px 0; color: #e36b5e">
                    Add Pillowy to Home Screen
                </h3>
                <div class="install-steps">
                    <div class="step-item">
                        <div class="step-icon">1</div>
                        <div class="step-text">
                            Open this page in
                            <strong style="color: #007aff">Safari</strong> (not
                            Edge/Chrome)
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-icon">2</div>
                        <div class="step-text">
                            Tap the
                            <strong
                                style="
                                    background: #007aff;
                                    color: white;
                                    padding: 2px 8px;
                                    border-radius: 16px;
                                "
                                >Share</strong
                            >
                            button 📤
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-icon">3</div>
                        <div class="step-text">
                            Scroll down and tap
                            <strong>"Add to Home Screen"</strong> ➕
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-icon">4</div>
                        <div class="step-text">
                            Tap <strong>"Add"</strong> → Open from home screen
                            ✨
                        </div>
                    </div>
                </div>
                <div class="guide-button-group">
                    <button id="closeGuideModal" style="flex: 1">
                        Got it!
                    </button>
                </div>
            </div>
        </div>

        <div class="app-container">
            <div class="status-bar">
                <span>✨ Pillowy</span><span>🔔 🌸</span>
            </div>

            <!-- HOME: Streak + today reminders -->
            <div id="homePage" class="page active-page">
                <!-- Browser Warning for non-Safari iOS -->
                <div
                    class="browser-warning-card"
                    id="browserWarningCard"
                    style="display: none"
                >
                    <div class="browser-icon" id="browserIcon">⚠️</div>
                    <h3 id="warningTitle">Safari Required</h3>
                    <p id="warningMessage">
                        You're using a browser that doesn't support
                        notifications or "Add to Home Screen" on iOS.
                    </p>
                    <button class="open-in-safari-btn" id="openInSafariBtn">
                        <span class="safari-icon">🧭</span> Open in Safari
                    </button>
                    <button class="dismiss-warning" id="dismissWarningBtn">
                        Dismiss (features won't work)
                    </button>
                </div>

                <div class="streak-card">
                    <div>🌸 CURRENT STREAK 🌸</div>
                    <div class="streak-number" id="streakValue">1</div>
                    <div>Days of being amazing!</div>
                </div>
                <div class="section-title">
                    <span>💨 Today's Puffs</span>
                    <span class="view-all-link" id="viewAllLink">VIEW ALL</span>
                </div>
                <div class="reminder-card">
                    <div>
                        <div>🌞 MORNING ROUTINE</div>
                        <div>Vitamin C boost</div>
                    </div>
                    <div class="reminder-time">08:30 AM</div>
                </div>
                <div class="reminder-card">
                    <div>
                        <div>🌸 Midday Check-in</div>
                        <div>Gentle nudge</div>
                    </div>
                    <div class="reminder-time">12:00 PM</div>
                </div>

                <!-- iOS Add to Home Screen Guide (only shown on iOS Safari) -->
                <div
                    class="ios-guide-card"
                    id="iosGuideCard"
                    style="display: none"
                >
                    <div
                        style="
                            display: flex;
                            align-items: center;
                            gap: 8px;
                            margin-bottom: 8px;
                        "
                    >
                        <span style="font-size: 24px">📲</span>
                        <strong>iOS Notification Setup</strong>
                    </div>
                    <p style="margin-bottom: 12px">
                        To get reminders, add Pillowy to your home screen:
                    </p>
                    <button
                        id="showDetailedGuideBtn"
                        style="width: 100%; background: #e36b5e; padding: 10px"
                    >
                        📖 Show step-by-step guide
                    </button>
                </div>

                <div>
                    <button id="testNotifBtn" style="width: 100%">
                        🔔 Test notification
                    </button>
                </div>
                <div
                    id="notifyStatus"
                    class="notification-perm"
                    style="margin-top: 12px"
                >
                    <span>🔕 Notifications:</span>
                    <span id="permBadge">⚠️ Not allowed</span>
                    <button id="requestPermBtn" style="background: #b1826e">
                        Enable
                    </button>
                </div>
            </div>

            <!-- FOCUS TIMER with presets 25min, 1h, 2h -->
            <div id="focusPage" class="page">
                <div style="text-align: center; margin-bottom: 12px">
                    <span
                        style="
                            background: rgba(255, 230, 220, 0.6);
                            padding: 6px 16px;
                            border-radius: 40px;
                        "
                        >🧘 FOCUS SESSION</span
                    >
                </div>
                <div class="focus-card">
                    <h2>Deep Dreaming</h2>
                    <div class="preset-group">
                        <button class="preset-btn" data-minutes="25">
                            25 min
                        </button>
                        <button class="preset-btn" data-minutes="60">
                            1 hour
                        </button>
                        <button class="preset-btn" data-minutes="120">
                            2 hours
                        </button>
                    </div>
                    <div class="timer-display" id="timerDisplay">25:00</div>
                    <div class="marshie-message">
                        🐻‍❄️ Marshie is having a cozy nap...
                    </div>
                    <div
                        style="
                            display: flex;
                            gap: 12px;
                            justify-content: center;
                            margin-top: 8px;
                        "
                    >
                        <button id="startTimerBtn">▶ Start</button>
                        <button id="resetTimerBtn" class="btn-outline">
                            ⟳ Reset
                        </button>
                    </div>
                </div>
                <div class="notification-perm" style="justify-content: center">
                    <span>✨ timer will notify you when focus ends ✨</span>
                </div>
            </div>

            <!-- REWARDS + STREAK CALENDAR -->
            <div id="rewardsPage" class="page">
                <div class="streak-card">
                    <div><strong>CURRENT STREAK</strong></div>
                    <div class="streak-number" id="streakRewardsValue">1</div>
                    <div>Keep going! Unlock diamond badge at 21 days.</div>
                </div>
                <div class="section-title">📅 Streak Calendar</div>
                <div id="calendarGrid" class="calendar-grid"></div>
                <div class="badge-progress-container">
                    🏆 Badge progress:
                    <strong id="badgeProgress">1/21 days</strong>
                </div>
                <div style="margin-top: 24px">
                    <button id="mockCompleteTodayBtn" style="width: 100%">
                        ✨ Check-in today (streak +1)
                    </button>
                </div>
                <div style="margin-top: 12px">
                    <button
                        id="resetStreakBtn"
                        class="btn-outline"
                        style="width: 100%"
                    >
                        🔄 Reset Streak (Testing)
                    </button>
                </div>
            </div>

            <!-- SET: custom reminder -->
            <div id="snoozePage" class="page">
                <div class="glass-panel">
                    <div style="font-size: 20px; margin-bottom: 12px">
                        ⏰ Custom Reminder
                    </div>
                    <label style="font-weight: 500">Hour (24h format)</label>
                    <input
                        type="number"
                        id="customHour"
                        placeholder="14"
                        min="0"
                        max="23"
                        value="20"
                        style="margin-bottom: 12px"
                    />
                    <label style="font-weight: 500">Minute</label>
                    <input
                        type="number"
                        id="customMinute"
                        placeholder="30"
                        min="0"
                        max="59"
                        value="30"
                        style="margin-bottom: 12px"
                    />
                    <label style="font-weight: 500"
                        >Notification content (max 100 chars)</label
                    >
                    <textarea
                        id="customNotiText"
                        rows="2"
                        maxlength="100"
                        placeholder="e.g., Time to take your vitamins 🌟"
                    >
Pillowy nudge: stay mindful ✨</textarea
                    >
                    <div
                        style="font-size: 12px; color: #9b6b5e; margin-top: 4px"
                        id="charCount"
                    >
                        0/100
                    </div>
                    <button
                        id="scheduleCustomNudgeBtn"
                        style="margin-top: 16px; width: 100%"
                    >
                        Set custom reminder & notify
                    </button>
                    <div
                        style="margin-top: 12px; font-size: 13px; opacity: 0.8"
                    >
                        💡 Reminder will trigger at specified time (next
                        occurrence if passed)
                    </div>
                </div>
            </div>

            <div class="tab-bar">
                <button class="tab-item" data-page="homePage">
                    <span class="tab-icon">🏠</span><span>TODAY</span>
                </button>
                <button class="tab-item" data-page="focusPage">
                    <span class="tab-icon">⏱️</span><span>TIMER</span>
                </button>
                <button class="tab-item" data-page="rewardsPage">
                    <span class="tab-icon">🎁</span><span>REWARDS</span>
                </button>
                <button class="tab-item" data-page="snoozePage">
                    <span class="tab-icon">😴</span><span>SET</span>
                </button>
            </div>
        </div>
        <div id="toastMessage" class="toast-msg" style="opacity: 0">✨</div>

        <script>
            (function () {
                "use strict";

                // ----------------------- STATE -----------------------
                let currentStreak = 1;
                const todayDate = new Date();
                todayDate.setHours(0, 0, 0, 0);

                let focusInterval = null;
                let focusSecondsRemaining = 25 * 60;
                let activePreset = 25;
                const timerDisplayEl = document.getElementById("timerDisplay");

                // Modal handling (Confirm)
                let modalResolve = null;
                const modalOverlay = document.getElementById("confirmModal");
                const modalMessage = document.getElementById(
                    "confirmModalMessage",
                );
                const modalCancel =
                    document.getElementById("confirmModalCancel");
                const modalOk = document.getElementById("confirmModalOk");

                // Install Guide Modal
                const installGuideModal =
                    document.getElementById("installGuideModal");
                const showGuideBtn = document.getElementById(
                    "showDetailedGuideBtn",
                );
                const closeGuideBtn =
                    document.getElementById("closeGuideModal");

                // Browser Warning Elements
                const browserWarningCard =
                    document.getElementById("browserWarningCard");
                const browserIcon = document.getElementById("browserIcon");
                const warningTitle = document.getElementById("warningTitle");
                const warningMessage =
                    document.getElementById("warningMessage");
                const openInSafariBtn =
                    document.getElementById("openInSafariBtn");
                const dismissWarningBtn =
                    document.getElementById("dismissWarningBtn");

                function showModal(message) {
                    return new Promise((resolve) => {
                        modalResolve = resolve;
                        modalMessage.innerText = message;
                        modalOverlay.classList.add("show");
                    });
                }

                function hideModal() {
                    modalOverlay.classList.remove("show");
                }

                modalCancel.addEventListener("click", () => {
                    if (modalResolve) modalResolve(false);
                    hideModal();
                });

                modalOk.addEventListener("click", () => {
                    if (modalResolve) modalResolve(true);
                    hideModal();
                });

                modalOverlay.addEventListener("click", (e) => {
                    if (e.target === modalOverlay) {
                        if (modalResolve) modalResolve(false);
                        hideModal();
                    }
                });

                // Install Guide Modal Events
                if (showGuideBtn) {
                    showGuideBtn.addEventListener("click", () => {
                        installGuideModal.classList.add("show");
                    });
                }

                if (closeGuideBtn) {
                    closeGuideBtn.addEventListener("click", () => {
                        installGuideModal.classList.remove("show");
                    });
                }

                installGuideModal.addEventListener("click", (e) => {
                    if (e.target === installGuideModal) {
                        installGuideModal.classList.remove("show");
                    }
                });

                // Browser Detection Functions
                function isiOS() {
                    return (
                        /iPhone|iPad|iPod/i.test(navigator.userAgent) &&
                        !window.MSStream
                    );
                }

                function isSafari() {
                    const ua = navigator.userAgent;
                    return (
                        /Safari/i.test(ua) &&
                        !/CriOS|FxiOS|OPiOS|mercury|EdgiOS/i.test(ua)
                    );
                }

                function getBrowserName() {
                    const ua = navigator.userAgent;
                    if (/EdgiOS/i.test(ua)) return "Edge";
                    if (/CriOS/i.test(ua)) return "Chrome";
                    if (/FxiOS/i.test(ua)) return "Firefox";
                    if (/OPiOS/i.test(ua)) return "Opera";
                    return "Browser";
                }

                function isPWA() {
                    return window.navigator.standalone === true;
                }

                // Show warning for non-Safari iOS browsers
                function checkBrowserAndShowWarning() {
                    if (!isiOS()) {
                        // Not iOS - hide warning
                        if (browserWarningCard)
                            browserWarningCard.style.display = "none";
                        return false;
                    }

                    if (isPWA()) {
                        // Already installed as PWA
                        if (browserWarningCard)
                            browserWarningCard.style.display = "none";
                        if (document.getElementById("iosGuideCard")) {
                            document.getElementById(
                                "iosGuideCard",
                            ).style.display = "none";
                        }
                        return false;
                    }

                    if (!isSafari()) {
                        // iOS but not Safari - show warning
                        const browserName = getBrowserName();
                        if (browserWarningCard) {
                            browserWarningCard.style.display = "block";
                            browserIcon.innerText =
                                browserName === "Edge"
                                    ? "🌐"
                                    : browserName === "Chrome"
                                      ? "🔴"
                                      : "🦊";
                            warningTitle.innerText = `${browserName} Cannot Use Notifications`;
                            warningMessage.innerText = `${browserName} on iOS doesn't support "Add to Home Screen" or notifications. Please open this page in Safari.`;
                        }

                        // Hide normal guide
                        if (document.getElementById("iosGuideCard")) {
                            document.getElementById(
                                "iosGuideCard",
                            ).style.display = "none";
                        }
                        return true;
                    } else {
                        // iOS Safari - show normal guide
                        if (browserWarningCard)
                            browserWarningCard.style.display = "none";
                        return false;
                    }
                }

                function checkiOSAndShowGuide() {
                    const guideCard = document.getElementById("iosGuideCard");
                    const permBadge = document.getElementById("permBadge");
                    const reqBtn = document.getElementById("requestPermBtn");

                    if (!isiOS()) {
                        if (guideCard) guideCard.style.display = "none";
                        return;
                    }

                    if (isPWA()) {
                        if (guideCard) guideCard.style.display = "none";
                        if (permBadge) permBadge.innerText = "✅ PWA Ready";
                        if (reqBtn) reqBtn.disabled = false;
                        return;
                    }

                    if (isSafari()) {
                        // iOS Safari tab - show guide
                        if (guideCard) guideCard.style.display = "block";
                        if (permBadge)
                            permBadge.innerText = "📲 Add to Home Screen";
                        if (reqBtn) reqBtn.disabled = true;
                    }
                }

                // Open in Safari button handler
                if (openInSafariBtn) {
                    openInSafariBtn.addEventListener("click", () => {
                        // Copy current URL to clipboard
                        const url = window.location.href;

                        // Try to open in Safari using x-web-search scheme
                        // This doesn't directly open Safari but shows instruction
                        showToast(
                            "📋 URL copied! Open Safari and paste it.",
                            4000,
                        );

                        // Copy to clipboard
                        navigator.clipboard?.writeText(url).catch(() => {
                            prompt("Copy this URL and open in Safari:", url);
                        });

                        // Show detailed guide
                        installGuideModal.classList.add("show");
                    });
                }

                // Dismiss warning button
                if (dismissWarningBtn) {
                    dismissWarningBtn.addEventListener("click", () => {
                        if (browserWarningCard)
                            browserWarningCard.style.display = "none";
                        showToast(
                            "⚠️ Notifications won't work in this browser",
                            3000,
                        );
                    });
                }

                // ----------------------- STREAK LOGIC (FIXED) -----------------------
                function loadStreakData() {
                    const savedStreak = localStorage.getItem(
                        "pillowyStreak_glassy_v2",
                    );
                    const lastCheckinStr = localStorage.getItem(
                        "lastCheckinDate_glassy",
                    );

                    if (savedStreak && !isNaN(parseInt(savedStreak))) {
                        currentStreak = parseInt(savedStreak);
                    } else {
                        currentStreak = 1;
                    }

                    if (lastCheckinStr) {
                        const lastDate = new Date(lastCheckinStr);
                        lastDate.setHours(0, 0, 0, 0);

                        const timeDiff =
                            todayDate.getTime() - lastDate.getTime();
                        const daysDiff = Math.floor(
                            timeDiff / (1000 * 60 * 60 * 24),
                        );

                        if (daysDiff > 1) {
                            currentStreak = 1;
                            localStorage.setItem(
                                "pillowyStreak_glassy_v2",
                                currentStreak,
                            );
                        }
                    }

                    updateStreakUI();
                }

                function updateCalendarUI() {
                    const container = document.getElementById("calendarGrid");
                    if (!container) return;

                    const checkedDates = JSON.parse(
                        localStorage.getItem("checkedDatesArray") || "[]",
                    );
                    let calHtml = "";

                    const startDate = new Date(todayDate);
                    startDate.setDate(startDate.getDate() - 7);

                    for (let i = 0; i < 14; i++) {
                        const day = new Date(startDate);
                        day.setDate(startDate.getDate() + i);
                        day.setHours(0, 0, 0, 0);

                        const dayNum = day.getDate();
                        const isToday = day.getTime() === todayDate.getTime();
                        const isChecked = checkedDates.includes(
                            day.toDateString(),
                        );

                        let additionalClass = "";
                        if (isToday) additionalClass = "today";
                        else if (isChecked) additionalClass = "checked";

                        calHtml += `<div class="cal-day ${additionalClass}">${dayNum}</div>`;
                    }

                    container.innerHTML = calHtml;
                }

                function updateStreakUI() {
                    document
                        .querySelectorAll("#streakValue, #streakRewardsValue")
                        .forEach((el) => {
                            if (el) el.innerText = currentStreak;
                        });
                    const badgeEl = document.getElementById("badgeProgress");
                    if (badgeEl) {
                        const displayStreak = Math.min(currentStreak, 21);
                        badgeEl.innerText = `${displayStreak}/21 days`;
                    }
                    updateCalendarUI();
                }

                function markTodayComplete() {
                    const todayStr = todayDate.toDateString();
                    let checkedDates = JSON.parse(
                        localStorage.getItem("checkedDatesArray") || "[]",
                    );

                    if (checkedDates.includes(todayStr)) {
                        showToast("🌟 You already checked in today!");
                        return;
                    }

                    const lastCheckinStr = localStorage.getItem(
                        "lastCheckinDate_glassy",
                    );
                    let shouldIncreaseStreak = true;

                    if (lastCheckinStr) {
                        const lastDate = new Date(lastCheckinStr);
                        lastDate.setHours(0, 0, 0, 0);
                        const yesterday = new Date(todayDate);
                        yesterday.setDate(yesterday.getDate() - 1);

                        if (lastDate.getTime() !== yesterday.getTime()) {
                            currentStreak = 1;
                            shouldIncreaseStreak = false;
                        }
                    }

                    if (shouldIncreaseStreak && lastCheckinStr) {
                        currentStreak += 1;
                    } else if (!lastCheckinStr) {
                        currentStreak = 1;
                    }

                    localStorage.setItem("lastCheckinDate_glassy", todayStr);
                    checkedDates.push(todayStr);
                    localStorage.setItem(
                        "checkedDatesArray",
                        JSON.stringify(checkedDates),
                    );
                    localStorage.setItem(
                        "pillowyStreak_glassy_v2",
                        currentStreak,
                    );

                    updateStreakUI();
                    showToast(
                        `🎉 Check-in successful! Streak: ${currentStreak} days`,
                    );

                    if (Notification.permission === "granted") {
                        try {
                            new Notification("Pillowy Reminders", {
                                body: `✨ Day ${currentStreak} completed! Keep glowing.`,
                            });
                        } catch (e) {
                            console.warn("Notification error:", e);
                        }
                    }
                }

                async function resetStreak() {
                    const confirmed = await showModal(
                        "Reset streak to 1? This is for testing purposes.",
                    );
                    if (confirmed) {
                        currentStreak = 1;
                        localStorage.setItem(
                            "pillowyStreak_glassy_v2",
                            currentStreak,
                        );
                        localStorage.removeItem("lastCheckinDate_glassy");
                        localStorage.removeItem("checkedDatesArray");
                        updateStreakUI();
                        showToast("🔄 Streak has been reset to 1");
                    }
                }

                // ----------------------- NOTIFICATIONS -----------------------
                function updateNotifUI() {
                    const badgeSpan = document.getElementById("permBadge");
                    if (!badgeSpan) return;

                    if (isiOS() && !isPWA() && !isSafari()) {
                        badgeSpan.innerText = "❌ Use Safari";
                        return;
                    }

                    if (isiOS() && !isPWA()) {
                        badgeSpan.innerText = "📲 Add to Home Screen";
                        return;
                    }

                    if (Notification.permission === "granted") {
                        badgeSpan.innerText = "✅ Enabled";
                    } else if (Notification.permission === "denied") {
                        badgeSpan.innerText = "❌ Blocked";
                    } else {
                        badgeSpan.innerText = "⚠️ Not allowed";
                    }
                }

                function requestNotificationPermission() {
                    if (!("Notification" in window)) {
                        showToast("Browser not supported");
                        return;
                    }

                    // Non-Safari iOS
                    if (isiOS() && !isSafari()) {
                        installGuideModal.classList.add("show");
                        showToast("⚠️ Please open this page in Safari", 3000);
                        return;
                    }

                    // iOS Safari not installed
                    if (isiOS() && !isPWA()) {
                        installGuideModal.classList.add("show");
                        return;
                    }

                    Notification.requestPermission().then((perm) => {
                        if (perm === "granted") {
                            showToast("🔔 Notifications enabled!");
                            updateNotifUI();
                            try {
                                new Notification("Pillowy Reminders", {
                                    body: "Cozy reminders active 🌸",
                                });
                            } catch (e) {}
                        } else {
                            showToast("Permission denied");
                            updateNotifUI();
                        }
                    });
                }

                function sendLocalNotification(title, body) {
                    if (Notification.permission === "granted") {
                        try {
                            new Notification(title, { body: body });
                            showToast(`📬 ${title}`);
                        } catch (e) {
                            showToast("⚠️ Notification blocked");
                        }
                    } else if (isiOS() && !isPWA()) {
                        if (!isSafari()) {
                            showToast(
                                "📲 Open in Safari, then Add to Home Screen",
                                4000,
                            );
                            installGuideModal.classList.add("show");
                        } else {
                            showToast(
                                "📲 Add Pillowy to Home Screen first",
                                3000,
                            );
                        }
                    } else {
                        showToast("⚠️ Enable notifications first");
                    }
                }

                // ----------------------- TIMER -----------------------
                function updateTimerUI() {
                    if (!timerDisplayEl) return;
                    const mins = Math.floor(focusSecondsRemaining / 60);
                    const secs = focusSecondsRemaining % 60;
                    timerDisplayEl.innerText = `${mins.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
                }

                function setPreset(minutes) {
                    if (focusInterval) stopTimer();
                    focusSecondsRemaining = minutes * 60;
                    activePreset = minutes;
                    updateTimerUI();

                    document.querySelectorAll(".preset-btn").forEach((btn) => {
                        const btnMins = parseInt(btn.dataset.minutes);
                        if (btnMins === minutes) {
                            btn.classList.add("active-preset");
                        } else {
                            btn.classList.remove("active-preset");
                        }
                    });
                }

                function stopTimer() {
                    if (focusInterval) {
                        clearInterval(focusInterval);
                        focusInterval = null;
                    }
                }

                function startFocusTimer() {
                    if (focusInterval) stopTimer();
                    if (focusSecondsRemaining <= 0) {
                        setPreset(activePreset || 25);
                    }

                    focusInterval = setInterval(() => {
                        if (focusSecondsRemaining <= 1) {
                            stopTimer();
                            focusSecondsRemaining = 0;
                            updateTimerUI();
                            sendLocalNotification(
                                "🧘 Focus complete!",
                                `Your ${activePreset}min session finished. Marshie says well done!`,
                            );
                        } else {
                            focusSecondsRemaining--;
                            updateTimerUI();
                        }
                    }, 1000);
                }

                function resetFocusTimer() {
                    stopTimer();
                    focusSecondsRemaining = activePreset * 60;
                    updateTimerUI();
                }

                // ----------------------- CUSTOM REMINDER -----------------------
                function scheduleCustomReminder() {
                    if (Notification.permission !== "granted") {
                        if (isiOS() && !isPWA()) {
                            if (!isSafari()) {
                                showToast("📲 Open in Safari first", 3500);
                            } else {
                                showToast(
                                    "📲 Add to Home Screen to use reminders",
                                    3500,
                                );
                            }
                            installGuideModal.classList.add("show");
                        } else {
                            showToast("Please enable notifications first.");
                        }
                        return;
                    }

                    const hour = parseInt(
                        document.getElementById("customHour").value,
                    );
                    const minute = parseInt(
                        document.getElementById("customMinute").value,
                    );
                    let customMsg = document
                        .getElementById("customNotiText")
                        .value.trim();

                    if (isNaN(hour) || hour < 0 || hour > 23) {
                        showToast("Hour must be 0-23");
                        return;
                    }
                    if (isNaN(minute) || minute < 0 || minute > 59) {
                        showToast("Minute 0-59");
                        return;
                    }
                    if (customMsg === "") customMsg = "Pillowy gentle reminder";

                    const now = new Date();
                    const target = new Date();
                    target.setHours(hour, minute, 0, 0);

                    if (target.getTime() <= now.getTime()) {
                        target.setDate(target.getDate() + 1);
                    }

                    const delay = target.getTime() - now.getTime();
                    if (delay > 2147483647) {
                        showToast("Too far in future, try within 24 days");
                        return;
                    }

                    setTimeout(() => {
                        sendLocalNotification(
                            "⏰ Custom Pillowy Reminder",
                            customMsg,
                        );
                    }, delay);

                    const timeStr = `${hour.toString().padStart(2, "0")}:${minute.toString().padStart(2, "0")}`;
                    showToast(`Reminder set at ${timeStr} with your message.`);
                }

                // ----------------------- UI HELPERS -----------------------
                function switchPage(pageId) {
                    document
                        .querySelectorAll(".page")
                        .forEach((p) => p.classList.remove("active-page"));
                    const targetPage = document.getElementById(pageId);
                    if (targetPage) targetPage.classList.add("active-page");

                    document
                        .querySelectorAll(".tab-item")
                        .forEach((tab) => tab.classList.remove("active"));
                    const activeTab = Array.from(
                        document.querySelectorAll(".tab-item"),
                    ).find((tab) => tab.dataset.page === pageId);
                    if (activeTab) activeTab.classList.add("active");

                    if (pageId !== "focusPage" && focusInterval) {
                        showToast("⏱️ Timer still running in background", 1500);
                    }
                }

                function showToast(msg, duration = 2000) {
                    const toast = document.getElementById("toastMessage");
                    toast.innerText = msg;
                    toast.style.opacity = "1";
                    setTimeout(() => {
                        toast.style.opacity = "0";
                    }, duration);
                }

                function updateCharCount() {
                    const textarea = document.getElementById("customNotiText");
                    const charCount = document.getElementById("charCount");
                    if (textarea && charCount) {
                        const len = textarea.value.length;
                        charCount.innerText = `${len}/100`;
                        charCount.style.color =
                            len > 90 ? "#e36b5e" : "#9b6b5e";
                    }
                }

                // ----------------------- INITIALIZATION -----------------------
                document.addEventListener("DOMContentLoaded", () => {
                    loadStreakData();

                    // Check browser first
                    const isUnsupportedBrowser = checkBrowserAndShowWarning();
                    checkiOSAndShowGuide();

                    updateNotifUI();
                    setPreset(25);

                    // Event listeners
                    document.querySelectorAll(".preset-btn").forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const mins = parseInt(btn.dataset.minutes);
                            setPreset(mins);
                        });
                    });

                    document
                        .getElementById("startTimerBtn")
                        ?.addEventListener("click", startFocusTimer);
                    document
                        .getElementById("resetTimerBtn")
                        ?.addEventListener("click", resetFocusTimer);
                    document
                        .getElementById("mockCompleteTodayBtn")
                        ?.addEventListener("click", markTodayComplete);
                    document
                        .getElementById("resetStreakBtn")
                        ?.addEventListener("click", resetStreak);
                    document
                        .getElementById("scheduleCustomNudgeBtn")
                        ?.addEventListener("click", scheduleCustomReminder);
                    document
                        .getElementById("testNotifBtn")
                        ?.addEventListener("click", () => {
                            sendLocalNotification(
                                "Pillowy Reminder 💊",
                                "Stay consistent & cozy!",
                            );
                        });
                    document
                        .getElementById("requestPermBtn")
                        ?.addEventListener(
                            "click",
                            requestNotificationPermission,
                        );
                    document
                        .getElementById("viewAllLink")
                        ?.addEventListener("click", () => {
                            switchPage("rewardsPage");
                        });

                    document.querySelectorAll(".tab-item").forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const pageId = btn.dataset.page;
                            if (pageId) switchPage(pageId);
                        });
                    });

                    const textarea = document.getElementById("customNotiText");
                    if (textarea) {
                        textarea.addEventListener("input", updateCharCount);
                        updateCharCount();
                    }

                    updateCalendarUI();
                    switchPage("homePage");

                    if (Notification.permission === "granted") {
                        updateNotifUI();
                    }

                    window.addEventListener("beforeunload", () => {
                        if (focusInterval) {
                            clearInterval(focusInterval);
                        }
                    });
                });
            })();
        </script>
    </body>
</html>
